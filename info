#!/usr/bin/env bash
set -euo pipefail

echo "=== Host / Session ==="
echo "User: $(whoami)"
echo "Hostname: $(hostname)"
echo "Shell: $SHELL"
echo "XDG_SESSION_TYPE: ${XDG_SESSION_TYPE:-unknown}"
echo "DISPLAY: ${DISPLAY:-<not set>}"
echo "XDG_RUNTIME_DIR: ${XDG_RUNTIME_DIR:-<not set>}"
echo

echo "=== Desktop / Compositor Info ==="
# KDE / KWin detection
if command -v qdbus >/dev/null 2>&1; then
  echo "qdbus present; trying to detect KWin..."
  qdbus org.kde.KWin /KWin org.kde.KWin.supportsMultipleDesktops 2>/dev/null || true
fi
if command -v plasmashell >/dev/null 2>&1; then
  echo "plasmashell: $(plasmashell --version 2>/dev/null || echo 'unknown')"
fi
echo

echo "=== Monitor enumeration ==="
if [ "${XDG_SESSION_TYPE:-}" = "x11" ] && command -v xrandr >/dev/null 2>&1; then
  echo "-- xrandr --listmonitors --"
  xrandr --listmonitors 2>/dev/null || xrandr --query 2>/dev/null
elif command -v swaymsg >/dev/null 2>&1; then
  echo "-- swaymsg get_outputs --"
  swaymsg -t get_outputs
elif command -v wlr-randr >/dev/null 2>&1; then
  echo "-- wlr-randr --"
  wlr-randr
else
  echo "No standard monitor tool found (xrandr/swaymsg/wlr-randr). Listing DRM connectors:"
  ls -l /sys/class/drm/*/status 2>/dev/null || true
fi
echo

echo "=== Window system / windows (best-effort) ==="
if [ "${XDG_SESSION_TYPE:-}" = "x11" ] && command -v wmctrl >/dev/null 2>&1; then
  echo "-- wmctrl -lx (class, title) --"
  wmctrl -lx
  echo
  echo "-- Konsole windows (wmctrl grep konsole) --"
  wmctrl -lx | grep -i konsole || true
  echo
  echo "-- For each konsole window: WM_CLASS and WM_NAME (xprop) --"
  while read -r line; do
    wid=$(awk '{print $1}' <<<"$line")
    echo "Window ID: $wid"
    xprop -id "$wid" WM_CLASS WM_NAME _NET_WM_PID 2>/dev/null || true
    echo "----"
  done < <(wmctrl -lx | grep -i konsole | awk '{print $1}')
elif [ "${XDG_SESSION_TYPE:-}" = "wayland" ]; then
  echo "Wayland session detected. X11 tools (wmctrl/xprop) are not available on Wayland."
  echo "Attempting to list KDE windows via qdbus (KWin) if available..."
  if command -v qdbus >/dev/null 2>&1; then
    echo "-- qdbus org.kde.KWin /KWin org.kde.KWin.windows --"
    qdbus org.kde.KWin /KWin org.kde.KWin.windows 2>/dev/null || true
  else
    echo "qdbus not available; cannot enumerate Wayland windows from here."
  fi
else
  echo "Neither X11 nor Wayland detection succeeded or required tools missing."
fi
echo

echo "=== Processes: konsole, tmux, nvtop, htop ==="
ps -ef | egrep 'konsole|tmux|nvtop|htop' | egrep -v 'egrep|monitor-detect' || true
echo

echo "=== tmux config and title settings ==="
echo "-- ~/.tmux.conf (first 200 lines if exists) --"
if [ -f "${HOME}/.tmux.conf" ]; then
  sed -n '1,200p' "${HOME}/.tmux.conf"
else
  echo "<no ~/.tmux.conf>"
fi
echo
echo "-- tmux show-options -g (if tmux server running) --"
if command -v tmux >/dev/null 2>&1; then
  tmux show-options -g 2>/dev/null || true
else
  echo "tmux not installed or not in PATH"
fi
echo

echo "=== Konsole launch line in your script ==="
if [ -f "${HOME}/.local/bin/monitor-split.sh" ]; then
  echo "-- head of script --"
  sed -n '1,200p' "${HOME}/.local/bin/monitor-split.sh"
else
  echo "<no ~/.local/bin/monitor-split.sh>"
fi
echo

echo "=== KWin rules file (kwinrulesrc) ==="
if [ -f "${HOME}/.config/kwinrulesrc" ]; then
  sed -n '1,240p' "${HOME}/.config/kwinrulesrc"
else
  echo "<no ~/.config/kwinrulesrc>"
fi
echo

echo "=== Autostart .desktop and systemd unit ==="
echo "-- ~/.config/autostart/monitor-split.desktop --"
if [ -f "${HOME}/.config/autostart/monitor-split.desktop" ]; then
  sed -n '1,200p' "${HOME}/.config/autostart/monitor-split.desktop"
else
  echo "<no ~/.config/autostart/monitor-split.desktop>"
fi
echo
echo "-- systemd user unit status --"
if command -v systemctl >/dev/null 2>&1; then
  systemctl --user status monitor-split.service --no-pager || true
  echo
  echo "-- journalctl (last 200 lines) --"
  journalctl --user -u monitor-split.service -n 200 --no-pager || true
else
  echo "systemctl not available"
fi
echo

echo "=== Helpful hints summary ==="
echo "1) If X11: monitor indices from xrandr listmonitors show index numbers (0..N)."
echo "2) If Wayland: KWin controls placement; use Screen property in kwinrulesrc (index starts at 0)."
echo "3) tmux can overwrite window title; check ~/.tmux.conf for set-titles settings."
echo "4) If Konsole still overrides rules, ensure 'Ignore requested geometry' is forced in kwinrulesrc."
echo
echo "=== End of report ==="
SH
chmod +x /tmp/monitor-detect.sh
echo "Script written to /tmp/monitor-detect.sh — running now..."
