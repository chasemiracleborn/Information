chase@Tits:~$ # hardware & session
uname -a
cat /proc/cmdline
lsb_release -a || cat /etc/fedora-release
echo "XDG_SESSION_TYPE=$XDG_SESSION_TYPE"

# GPU & drivers
lspci -nn | grep -iE 'vga|3d'
nvidia-smi -q 2>/dev/null || true
modinfo nvidia 2>/dev/null || true

# logs
dmesg | tail -n 200
journalctl -b -n 200 --no-pager
journalctl -b _COMM=kwin_wayland -n 200 --no-pager
journalctl -b -u sddm -n 200 --no-pager

# KWin output config
ls -l ~/.config/kwinoutputconfig.json
cat ~/.config/kwinoutputconfig.json 2>/dev/null | tail -n 50

# DPMS / power
loginctl show-session $(loginctl | awk '/seat0/ {print $1; exit}') -p Inhibitors || true
systemctl --user status plasma-powerdevil.service || true
