# ═══════════════════════════════════════════════════════════
set_hostname
ensure_rpmfusion_nonfree       # must run before any NVIDIA package ops
ensure_cachyos_copr            # must run before kernel/module checks
verify_and_fix_nvidia_setup    # must run before system_update
system_update                  # dnf upgrade + akmods --force
verify_nvidia_module           # sets NVIDIA_MODULE_OK
set_cachyos_kernel_default     # grubby primary + grub2-set-default fallback
install_cachyos_kernel_hook    # ensures future updates stay on CachyOS kernel
cleanup_system
setup_flatpak_remotes          # Flathub + Fedora OCI remotes
apply_gaming_sysctl
add_nfs_shares
export_metadata
finalize                       # reboot prompt gated on NVIDIA_MODULE_OK

log "PostInstallSetup finished"
