chase@Tits:~$ cat > ~/setup-monitor-split.sh <<'SH'
#!/usr/bin/env bash
set -euo pipefail

USER_HOME="$HOME"
BACKUP_DIR="$USER_HOME/.config/kwin-backup"
mkdir -p "$BACKUP_DIR"
KWINRC="$USER_HOME/.config/kwinrulesrc"
KWINRC_BAK="$BACKUP_DIR/kwinrulesrc.bak.$(date +%s)"
AUTOSTART_DIR="$USER_HOME/.config/autostart"
SERVICE_DIR="$USER_HOME/.config/systemd/user"
HELPER_SCRIPT="$USER_HOME/.local/bin/monitor-split-tmux.sh"
TMUX_UNIT="$SERVICE_DIR/monitor-split-tmux.service"
GUI_DESKTOP="$AUTOSTART_DIR/monitor-split.desktop"
ALT_UNIT="$SERVICE_DIR/monitor-split-gui.service"
DEBUG_FILE="$USER_HOME/Desktop/monitor-split-debug-$(date +%s).txt"

echo "Backing up kwinrulesrc if present..."
if [ -f "$KWINRC" ]; then
  cp -v "$KWINRC" "$KWINRC_BAK"
  echo "Backup saved to $KWINRC_BAK"
fi

echo "Step 1: create a systemd oneshot that ensures tmux session exists..."
mkdir -p "$SERVICE_DIR"
mkdir -p "$USER_HOME/.local/bin"
cat > "$HELPER_SCRIPT" <<'EOF'
#!/usr/bin/env bash
SESSION="sys"
if ! command -v tmux >/dev/null 2>&1; then
  echo "tmux not found" >&2
  exit 1
fi
if ! tmux has-session -t "$SESSION" 2>/dev/null; then
  tmux new-session -d -s "$SESSION" 'htop'
  tmux split-window -h -t "$SESSION" 'nvtop'
  tmux select-pane -t 0
fi
EOF
chmod +x "$HELPER_SCRIPT"

cat > "$TMUX_UNIT" <<EOF
[Unit]
Description=MonitorSplit tmux session (htop + nvtop)
After=default.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=$HELPER_SCRIPT
TimeoutStartSec=30

[Install]
WantedBy=default.target
EOF

echo "Step 2: create autostart .desktop to open Konsole with title MonitorSplit..."
mkdir -p "$AUTOSTART_DIR"
cat > "$GUI_DESKTOP" <<EOF
[Desktop Entry]
Type=Application
Name=Monitor Split Console
Exec=konsole --noclose --title "MonitorSplit" -e tmux attach -t sys
Icon=utilities-terminal
Terminal=false
X-GNOME-Autostart-enabled=true
EOF

echo "Step 3: write a clean MonitorSplit kwin rule block (strict match on title substring)..."
cat > /tmp/kwinrules_monitor_split.clean <<'EOF'
[MonitorSplit-Rule]
Description=MonitorSplit
wmclass=konsole
wmclassmatch=1
title=MonitorSplit
titlematch=3
ignoregeometry=true
ignoregeometryrule=2
noborder=true
noborderrule=2
closeable=false
closeablerule=2
maximizehoriz=true
maximizehorizrule=2
maximizevert=true
maximizevertrule=2
screen=3
screenrule=2
EOF

# Remove any existing MonitorSplit-Rule block and append the clean one
if [ -f "$KWINRC" ]; then
  awk 'BEGIN{RS="\\n\\n"; ORS="\\n\\n"} !/

\[MonitorSplit-Rule\]

/ {print}' "$KWINRC" > /tmp/kwinrulesrc.without_ms || true
  cat /tmp/kwinrulesrc.without_ms /tmp/kwinrules_monitor_split.clean > /tmp/kwinrulesrc.new || cp /tmp/kwinrules_monitor_split.clean /tmp/kwinrulesrc.new
else
  cp /tmp/kwinrules_monitor_split.clean /tmp/kwinrulesrc.new
fi
mv -v /tmp/kwinrulesrc.new "$KWINRC"

echo "Step 4: enable and start the tmux unit"
systemctl --user daemon-reload
systemctl --user enable --now monitor-split-tmux.service || true
systemctl --user status monitor-split-tmux.service --no-pager || true

echo "Attempting to reconfigure KWin rules (if qdbus available)..."
if command -v qdbus >/dev/null 2>&1; then
  qdbus org.kde.KWin /KWin reconfigure || true
else
  echo "qdbus not installed; you may need to log out and back in for KWin to pick up the new rule."
fi

echo "Step 5: launch Konsole with MonitorSplit title to test"
konsole --noclose --title "MonitorSplit" -e tmux attach -t sys & sleep 2

echo
echo "Checking tmux session and processes..."
tmux ls 2>/dev/null || echo "tmux session not found"
ps -ef | egrep 'tmux|nvtop|htop|konsole' | egrep -v 'egrep' || true

echo
read -p "Visually inspect the MonitorSplit window. Is it borderless, maximized, on monitor 4, and without a close button? (y/n) " ans
if [ "$ans" = "y" ] || [ "$ans" = "Y" ]; then
  echo "Great — primary approach succeeded."
  exit 0
fi

echo "Primary approach did not produce the desired result. Trying alternative approach: systemd will launch Konsole after a delay."

cat > "$ALT_UNIT" <<EOF
[Unit]
Description=MonitorSplit GUI launcher (Konsole)
After=graphical-session.target

[Service]
Type=simple
ExecStartPre=/bin/sleep 8
ExecStart=/usr/bin/konsole --noclose --title "MonitorSplit" -e tmux attach -t sys
Restart=on-failure
Environment=XDG_RUNTIME_DIR=%t
Environment=WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-0}

[Install]
WantedBy=default.target
EOF

systemctl --user daemon-reload
systemctl --user enable --now monitor-split-gui.service || true
systemctl --user status monitor-split-gui.service --no-pager || true

echo "Waiting 6 seconds for Konsole to appear..."
sleep 6

read -p "After the alternative approach, is the MonitorSplit window correct now? (y/n) " ans2
if [ "$ans2" = "y" ] || [ "$ans2" = "Y" ]; then
  echo "Alternative approach succeeded."
  exit 0
fi

echo "Both approaches failed. Collecting debug information to $DEBUG_FILE ..."

{
  echo "=== date ==="
  date
  echo
  echo "=== systemd user units status ==="
  systemctl --user status monitor-split-tmux.service --no-pager || true
  systemctl --user status monitor-split-gui.service --no-pager || true
  echo
  echo "=== journal for units ==="
  journalctl --user -u monitor-split-tmux.service -n 200 --no-pager || true
  journalctl --user -u monitor-split-gui.service -n 200 --no-pager || true
  echo
  echo "=== tmux sessions and panes ==="
  ps -eo user,pid,cmd | egrep 'tmux|konsole|nvtop|htop' | egrep -v 'egrep' || true
  tmux ls 2>/dev/null || true
  if tmux has-session -t sys 2>/dev/null; then
    tmux list-windows -t sys -F '#I:#W #{window_active} #{window_layout}' || true
    tmux list-panes -a -t sys -F '#S:#I.#P #{pane_index} #{pane_active} #{pane_current_command} #{pane_start_command}' || true
  fi
  echo
  echo "=== kwinrulesrc snippet ==="
  sed -n '/

\[MonitorSplit-Rule\]

/,/

\[/{p}' "$KWINRC" || true
  echo
  echo "=== environment variables relevant ==="
  echo "XDG_SESSION_TYPE=$XDG_SESSION_TYPE"
  echo "WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-<not set>}"
  echo "DISPLAY=${DISPLAY:-<not set>}"
  echo "XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-<not set>}"
  echo
  echo "=== device nodes and groups ==="
  ls -l /dev/dri/* 2>/dev/null || true
  ls -l /dev/nvidia* 2>/dev/null || true
  id $(whoami) || true
} > "$DEBUG_FILE"

echo "Debug file written to $DEBUG_FILE"
echo "Please upload that file to your GitHub repo or paste it here and I will inspect it."
echo "If you want me to revert everything now, run: bash ~/revert-monitor-split.sh"
exit 1
SH

chmod +x ~/setup-monitor-split.sh
echo "Setup and test script written to ~/setup-monitor-split.sh"
echo "Run it with: bash ~/setup-monitor-split.sh"
Setup and test script written to ~/setup-monitor-split.sh
Run it with: bash ~/setup-monitor-split.sh
