#!/usr/bin/env bash
# PostInstallSetup.sh
# Target: Fedora 43 · KDE Plasma Wayland · CachyOS kernel · RTX 5080 Blackwell
# Purpose: idempotent post-install prep for cloned gaming machines
# Usage:   sudo ./PostInstallSetup.sh [--dry-run] [--noninteractive --hostname NAME]
#          sudo ./PostInstallSetup.sh --help
set -euo pipefail

# ═══════════════════════════════════════════════════════════
# CONFIG
# ═══════════════════════════════════════════════════════════
SCRIPT_NAME="$(basename "$0")"
LOGFILE="/var/log/postinstall-$(date +%Y%m%d-%H%M%S).log"
DRY_RUN=0
NONINTERACTIVE=0
TARGET_HOSTNAME=""
ALLOW_FW_UPDATE=0
ALLOW_REMOVE_OLD_KERNELS=0

# Set after NVIDIA module verification; gates the reboot prompt.
NVIDIA_MODULE_OK=0

# The real user who invoked sudo (used for chown, cache paths, home dir ops)
REAL_USER="${SUDO_USER:-$USER}"
REAL_HOME="$(getent passwd "$REAL_USER" | cut -d: -f6)"

# CachyOS COPR — only bieszczaders/kernel-cachyos works on Fedora 43.
# bmanojlovic and sentry both 404 for f43 (confirmed from install history).
CACHYOS_COPR="bieszczaders/kernel-cachyos"

# NVIDIA: Blackwell (RTX 5080) requires open kernel modules.
# The closed driver does NOT support Blackwell. This macro enforces open builds.
NVIDIA_MACRO_FILE="/etc/rpm/macros.nvidia-kmod"
NVIDIA_MACRO_CONTENT="%_with_kmod_nvidia_open 1"

FSTAB_MARKER="# nfs-entries-by-postinstall"
NFS_ENTRIES=(
  "192.168.0.33:/mnt/MusicDrive/Music\t/mnt/Tits_Music\tnfs\tdefaults,nofail,_netdev,x-systemd.automount,x-systemd.idle-timeout=60\t0\t0"
  "192.168.0.33:/mnt/MediaStorage\t/mnt/Tits_Media\tnfs\tdefaults,nofail,_netdev,x-systemd.automount,x-systemd.idle-timeout=60\t0\t0"
)

# ═══════════════════════════════════════════════════════════
# HELPERS
# ═══════════════════════════════════════════════════════════
usage() {
  cat <<EOF
$SCRIPT_NAME — Fedora 43 Post-Install Setup for Gaming Clones
Target hardware: Ryzen 9 5950X · RTX 5080 Blackwell · KDE Plasma Wayland

Usage: sudo $SCRIPT_NAME [OPTIONS]

Options:
  --noninteractive           Run without prompts (requires --hostname)
  --dry-run                  Print actions without executing changes
  --hostname NAME            Set hostname noninteractively
  --allow-fw-update          Opt-in: apply firmware updates via fwupdmgr
  --allow-remove-old-kernels Opt-in: remove old kernels (keeps latest 2)
                             WARNING: always preserves at least one non-CachyOS
                             kernel as a fallback. Never remove your only fallback.
  --help                     Show this help

Examples:
  sudo $SCRIPT_NAME --dry-run
  sudo $SCRIPT_NAME --noninteractive --hostname GameRig-02
  sudo $SCRIPT_NAME --noninteractive --hostname GameRig-02 --allow-remove-old-kernels
EOF
}

log() {
  printf '[%s] %s\n' "$(date +'%F %T')" "$*" | tee -a "$LOGFILE"
}

# run: array-based executor. Safe quoting — no eval, no bash -c.
# Dry-run output is valid shell you can copy-paste.
run() {
  if [[ "$DRY_RUN" -eq 1 ]]; then
    printf '[DRY-RUN]'
    printf ' %q' "$@"
    printf '\n'
  else
    "$@"
  fi
}

backup_file() {
  local file="$1"
  if [[ -e "$file" ]]; then
    local bak="${file}.postinstall.bak.$(date +%s)"
    run cp -a -- "$file" "$bak"
    log "Backed up $file -> $bak"
  fi
}

die() {
  printf '\n[FATAL] %s\n' "$*" | tee -a "$LOGFILE" >&2
  exit 1
}

warn() {
  printf '[WARN]  %s\n' "$*" | tee -a "$LOGFILE"
}

ensure_root() {
  if [[ "$EUID" -ne 0 ]]; then
    die "Run this script with sudo: sudo $SCRIPT_NAME"
  fi
}

ensure_fedora() {
  if ! grep -qi 'fedora' /etc/os-release 2>/dev/null; then
    die "This script is Fedora-only. Refusing to run on non-Fedora system."
  fi
  local ver
  ver="$(grep -oP '(?<=^VERSION_ID=)\d+' /etc/os-release 2>/dev/null || echo '?')"
  log "Fedora $ver detected — OK"
}

# ═══════════════════════════════════════════════════════════
# ARGUMENT PARSING
# ═══════════════════════════════════════════════════════════
while [[ $# -gt 0 ]]; do
  case "$1" in
    --noninteractive)           NONINTERACTIVE=1;           shift   ;;
    --dry-run)                  DRY_RUN=1;                  shift   ;;
    --hostname)                 TARGET_HOSTNAME="$2";       shift 2 ;;
    --allow-fw-update)          ALLOW_FW_UPDATE=1;          shift   ;;
    --allow-remove-old-kernels) ALLOW_REMOVE_OLD_KERNELS=1; shift   ;;
    --help)                     usage; exit 0                       ;;
    *) echo "Unknown option: $1"; usage; exit 2                     ;;
  esac
done

if [[ "$NONINTERACTIVE" -eq 1 && -z "$TARGET_HOSTNAME" ]]; then
  die "--noninteractive requires --hostname NAME"
fi

trap 'log "Script exited. Log: $LOGFILE"' EXIT

# Write log header
{
  printf '\n%s\n' "$(printf '=%.0s' {1..60})"
  printf 'PostInstallSetup -- %s\n' "$(date)"
  printf 'dry-run=%s  noninteractive=%s  real-user=%s\n' \
    "$DRY_RUN" "$NONINTERACTIVE" "$REAL_USER"
  printf '%s\n\n' "$(printf '=%.0s' {1..60})"
} | tee -a "$LOGFILE"

ensure_root
ensure_fedora

# ═══════════════════════════════════════════════════════════
# 1. HOSTNAME
# ═══════════════════════════════════════════════════════════
set_hostname() {
  local hn="$TARGET_HOSTNAME"

  if [[ -z "$hn" ]]; then
    if [[ "$NONINTERACTIVE" -eq 1 ]]; then
      log "Hostname not provided; skipping"
      return 0
    fi
    read -rp "Enter new hostname (blank to skip): " hn
    if [[ -z "$hn" ]]; then
      log "Hostname skipped"
      return 0
    fi
  fi

  log "Setting hostname -> $hn"
  run hostnamectl set-hostname -- "$hn"

  if [[ "$DRY_RUN" -eq 0 ]]; then
    backup_file /etc/hosts
    if grep -qE '^127\.0\.1\.1' /etc/hosts 2>/dev/null; then
      sed -i "s/^127\.0\.1\.1.*/127.0.1.1\t${hn}/" /etc/hosts
    else
      printf '127.0.1.1\t%s\n' "$hn" >> /etc/hosts
    fi
  else
    log "[DRY-RUN] Would update /etc/hosts: 127.0.1.1 -> $hn"
  fi

  log "Hostname set to $hn"
}

# ═══════════════════════════════════════════════════════════
# 2. RPM FUSION NONFREE
#
# BUG FIX: akmod-nvidia-open lives in RPM Fusion nonfree.
# On a fresh clone this repo may not be enabled, causing all
# NVIDIA steps to silently fail. This must run before any
# NVIDIA package operations.
# ═══════════════════════════════════════════════════════════
ensure_rpmfusion_nonfree() {
  log "-- Ensuring RPM Fusion nonfree is enabled --"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    log "[DRY-RUN] Would ensure RPM Fusion nonfree repo is installed"
    return 0
  fi

  if rpm -q rpmfusion-nonfree-release &>/dev/null; then
    log "OK: RPM Fusion nonfree already installed"
    return 0
  fi

  local fedora_ver
  fedora_ver="$(rpm -E %fedora)"
  log "Installing RPM Fusion nonfree for Fedora $fedora_ver"
  dnf install -y \
    "https://download1.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-${fedora_ver}.noarch.rpm" \
    || die "Failed to enable RPM Fusion nonfree. Cannot proceed with NVIDIA setup."

  log "RPM Fusion nonfree enabled"
}

# ═══════════════════════════════════════════════════════════
# 3. CACHYOS COPR
#
# BUG FIX: On a fresh clone the CachyOS COPR may not be
# enabled. Without it, kernel-cachyos packages are
# unavailable and the NVIDIA module check finds nothing.
# ═══════════════════════════════════════════════════════════
ensure_cachyos_copr() {
  log "-- Ensuring CachyOS COPR is enabled --"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    log "[DRY-RUN] Would ensure COPR $CACHYOS_COPR is enabled"
    return 0
  fi

  # dnf copr list returns the enabled COPRs; check if ours is present
  if dnf copr list 2>/dev/null | grep -qF "bieszczaders/kernel-cachyos"; then
    log "OK: CachyOS COPR already enabled"
    return 0
  fi

  log "Enabling CachyOS COPR: $CACHYOS_COPR"
  dnf copr enable "$CACHYOS_COPR" -y \
    || die "Failed to enable CachyOS COPR ($CACHYOS_COPR). Check network and try again."
  log "CachyOS COPR enabled"
}

# ═══════════════════════════════════════════════════════════
# 4. NVIDIA SAFETY -- verify before touching anything else
#
# RTX 5080 Blackwell requires akmod-nvidia-open.
# The closed driver does not support Blackwell GPUs.
# A missing macro or wrong akmod package -> black screen on reboot.
# This section fixes both silently if possible, and hard-fails if not.
# ═══════════════════════════════════════════════════════════
verify_and_fix_nvidia_setup() {
  log "-- NVIDIA safety checks --"

  # 4a. Ensure the open-module macro exists and is correct.
  # Without this, akmods builds the closed module which cannot load on Blackwell.
  if [[ "$DRY_RUN" -eq 0 ]]; then
    if [[ ! -f "$NVIDIA_MACRO_FILE" ]] || \
       ! grep -qxF "$NVIDIA_MACRO_CONTENT" "$NVIDIA_MACRO_FILE" 2>/dev/null; then
      log "Writing $NVIDIA_MACRO_FILE (open module macro)"
      echo "$NVIDIA_MACRO_CONTENT" > "$NVIDIA_MACRO_FILE"
    else
      log "OK: NVIDIA open macro already set"
    fi
  else
    log "[DRY-RUN] Would ensure $NVIDIA_MACRO_FILE contains: $NVIDIA_MACRO_CONTENT"
  fi

  # 4b. Ensure akmod-nvidia-open is installed, not the closed akmod-nvidia.
  # If the closed variant is present, swap it. This is safe and idempotent.
  if rpm -q akmod-nvidia &>/dev/null && ! rpm -q akmod-nvidia-open &>/dev/null; then
    warn "akmod-nvidia (closed) detected -- swapping to akmod-nvidia-open (required for Blackwell)"
    run dnf swap --allowerasing akmod-nvidia akmod-nvidia-open -y || \
      die "Failed to swap to akmod-nvidia-open. Fix manually before rebooting."
  elif ! rpm -q akmod-nvidia-open &>/dev/null; then
    warn "akmod-nvidia-open not found -- installing"
    run dnf install -y akmod-nvidia-open || \
      die "Failed to install akmod-nvidia-open. Fix manually before rebooting."
  else
    log "OK: akmod-nvidia-open is installed"
  fi

  # 4c. Ensure nvidia-settings and nvidia-persistenced are present
  run dnf install -y nvidia-settings nvidia-persistenced || true

  log "NVIDIA safety checks complete"
}

# ═══════════════════════════════════════════════════════════
# 5. SYSTEM UPDATE + AKMODS
# ═══════════════════════════════════════════════════════════
system_update() {
  log "-- System update --"
  run dnf upgrade --refresh -y || true

  # Rebuild kernel modules for all installed kernels.
  # This is the step that builds the NVIDIA .ko for the CachyOS kernel.
  if command -v akmods &>/dev/null; then
    log "Running akmods --force (builds NVIDIA open module for CachyOS kernel)"
    run akmods --force || warn "akmods reported errors -- will verify modules below"
  fi

  log "System update complete"
}

# ═══════════════════════════════════════════════════════════
# 6. VERIFY NVIDIA MODULE BUILT FOR CACHYOS KERNEL
#
# This is the critical gate. If the module did not build,
# the reboot prompt is suppressed and you get clear instructions.
# ═══════════════════════════════════════════════════════════
verify_nvidia_module() {
  log "-- Verifying NVIDIA module for CachyOS kernel --"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    log "[DRY-RUN] Would check for nvidia*.ko under /lib/modules/*cachyos*/extra/"
    NVIDIA_MODULE_OK=1
    return 0
  fi

  # Find the installed CachyOS kernel version from RPM (most reliable source)
  local cachyos_kver
  cachyos_kver="$(rpm -qa --queryformat '%{VERSION}-%{RELEASE}.%{ARCH}\n' \
    kernel-cachyos-core 2>/dev/null | sort -V | tail -1)"

  if [[ -z "$cachyos_kver" ]]; then
    warn "No CachyOS kernel RPM found -- skipping NVIDIA module check"
    warn "Install CachyOS kernel with:"
    warn "  sudo dnf copr enable $CACHYOS_COPR -y"
    warn "  sudo dnf install kernel-cachyos kernel-cachyos-devel-matched"
    # Not a hard failure if CachyOS kernel is simply absent
    NVIDIA_MODULE_OK=1
    return 0
  fi

  log "CachyOS kernel: $cachyos_kver"
  local module_dir="/lib/modules/${cachyos_kver}/extra"

  # find recurses into subdirectories (e.g. extra/nvidia/nvidia.ko.xz),
  # so this correctly finds modules regardless of packaging layout.
  if find "$module_dir" -name 'nvidia*.ko*' 2>/dev/null | grep -q .; then
    log "OK: NVIDIA open module found for $cachyos_kver"
    NVIDIA_MODULE_OK=1
  else
    warn "FAIL: NVIDIA open module NOT found for $cachyos_kver"
    warn "  Module dir checked: $module_dir"
    warn "  Diagnose: journalctl -u akmods --no-pager | tail -80"
    warn "  Retry:    sudo akmods --force"
    NVIDIA_MODULE_OK=0
  fi
}

# ═══════════════════════════════════════════════════════════
# 7. SET CACHYOS KERNEL AS GRUB DEFAULT
#
# BUG FIX: grub2-set-default with a BLS entry ID is unreliable
# on Fedora 43 — it depends on GRUB_DEFAULT=saved being set and
# grubenv being writable. grubby --set-default with the vmlinuz
# path is what actually works (confirmed from install logs).
# We use grubby as primary with grub2-set-default as fallback.
# ═══════════════════════════════════════════════════════════
set_cachyos_kernel_default() {
  log "-- Setting CachyOS kernel as GRUB default --"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    log "[DRY-RUN] Would set CachyOS vmlinuz as grubby default"
    return 0
  fi

  # Find the newest CachyOS vmlinuz (grubby uses the vmlinuz path directly)
  local cachyos_vmlinuz
  cachyos_vmlinuz="$(find /boot -maxdepth 1 -name 'vmlinuz-*cachyos*' 2>/dev/null \
    | sort -V | tail -1)"

  if [[ -z "$cachyos_vmlinuz" ]]; then
    warn "No CachyOS vmlinuz found in /boot -- skipping"
    warn "Check: rpm -qa kernel-cachyos-core"
    return 0
  fi

  log "CachyOS vmlinuz: $cachyos_vmlinuz"

  # grubby is the reliable method on Fedora 43 BLS
  if command -v grubby &>/dev/null; then
    run grubby --set-default "$cachyos_vmlinuz" \
      || warn "grubby --set-default failed -- trying grub2-set-default fallback"
  fi

  # Fallback: BLS entry ID via grub2-set-default
  local cachyos_entry
  cachyos_entry="$(find /boot/loader/entries/ -name '*cachyos*' 2>/dev/null \
    | sort -V | tail -1)"
  if [[ -n "$cachyos_entry" ]]; then
    local entry_id
    entry_id="$(basename "$cachyos_entry" .conf)"
    run grub2-set-default "$entry_id" 2>/dev/null || true
  fi

  # grub2-mkconfig is not needed for BLS default selection, but keeps
  # non-BLS entries and the grub menu consistent.
  if command -v grub2-mkconfig &>/dev/null; then
    run grub2-mkconfig -o /boot/grub2/grub.cfg 2>/dev/null || true
    if [[ -d /boot/efi ]]; then
      run grub2-mkconfig -o /boot/efi/EFI/fedora/grub.cfg 2>/dev/null || true
    fi
  fi

  log "CachyOS kernel set as default boot entry"
}

# ═══════════════════════════════════════════════════════════
# 8. CACHYOS AUTO-DEFAULT HOOK
#
# BUG FIX: Without this hook, future CachyOS kernel updates
# (via dnf) won't automatically become the GRUB default.
# The stock Fedora kernel would silently reclaim the default
# boot position after the next update.
# ═══════════════════════════════════════════════════════════
install_cachyos_kernel_hook() {
  log "-- Installing CachyOS auto-default kernel hook --"

  local hook_dir="/etc/kernel/postinst.d"
  local hook_file="$hook_dir/99-cachy-default"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    log "[DRY-RUN] Would install $hook_file"
    return 0
  fi

  run mkdir -p "$hook_dir"

  # Only write if it doesn't already exist or has changed
  local hook_content
  hook_content='#!/bin/sh
# 99-cachy-default — installed by PostInstallSetup.sh
# After any kernel package install, make the newest CachyOS kernel the
# GRUB default so dnf updates do not silently revert to stock Fedora kernel.
set -e
DEFAULT_KERNEL=$(ls /boot/vmlinuz-*cachy* 2>/dev/null | sort -V | tail -1)
if [ -n "$DEFAULT_KERNEL" ]; then
    grubby --set-default "$DEFAULT_KERNEL"
fi'

  if [[ -f "$hook_file" ]] && \
     grep -qF 'grubby --set-default' "$hook_file" 2>/dev/null; then
    log "OK: CachyOS kernel hook already installed at $hook_file"
    return 0
  fi

  printf '%s\n' "$hook_content" > "$hook_file"
  chown root:root "$hook_file"
  chmod 755 "$hook_file"
  log "CachyOS kernel hook installed at $hook_file"
}

# ═══════════════════════════════════════════════════════════
# 9. CONSERVATIVE CLEANUP
# ═══════════════════════════════════════════════════════════
cleanup_system() {
  log "-- System cleanup --"

  run dnf clean all      || true
  run dnf autoremove -y  || true
  run rpm --rebuilddb    || true

  run journalctl --vacuum-size=200M || true

  # Flatpak unused runtimes
  if command -v flatpak &>/dev/null; then
    run flatpak uninstall --unused -y || true
  fi

  # KDE Discover: ensure Flatpak backend is installed.
  # Without this, Discover shows no Flatpak apps even with Flathub enabled.
  if ! rpm -q plasma-discover-flatpak &>/dev/null; then
    log "Installing plasma-discover-flatpak"
    run dnf install -y plasma-discover-flatpak || true
  else
    log "OK: plasma-discover-flatpak already installed"
  fi

  # KDE Discover: clear cache. This fixes the very common blank/missing app
  # listing on Fedora 39-43 — cache corruption is the #1 cause.
  if [[ "$DRY_RUN" -eq 0 ]]; then
    rm -rf "${REAL_HOME}/.cache/discover"       2>/dev/null || true
    rm -rf "${REAL_HOME}/.local/share/discover" 2>/dev/null || true
    log "Cleared KDE Discover cache for $REAL_USER"
  else
    log "[DRY-RUN] Would clear KDE Discover cache for $REAL_USER"
  fi

  # BUG FIX: The original script used:
  #   find /usr/bin /usr/local/bin -xtype l -delete
  # This is dangerous — it removes ALL broken symlinks in system bin dirs,
  # including alternatives-managed paths that are intentionally broken
  # during package transitions. We now only clean /usr/local/bin which is
  # safe (user-managed), and leave /usr/bin strictly alone.
  run find /usr/local/bin -xtype l -delete 2>/dev/null || true

  # Block and remove Snap entirely.
  # Not installed on Fedora by default, but this ensures it can never arrive.
  if rpm -q snapd &>/dev/null; then
    log "Removing snapd"
    run dnf remove -y snapd || true
    run rm -rf /var/cache/snapd/ || true
    run rm -rf "${REAL_HOME}/snap" || true
  fi
  if ! grep -q 'exclude=snapd' /etc/dnf/dnf.conf 2>/dev/null; then
    if [[ "$DRY_RUN" -eq 0 ]]; then
      echo "exclude=snapd" >> /etc/dnf/dnf.conf
      log "Added 'exclude=snapd' to /etc/dnf/dnf.conf"
    else
      log "[DRY-RUN] Would add 'exclude=snapd' to /etc/dnf/dnf.conf"
    fi
  else
    log "OK: snapd already excluded in dnf.conf"
  fi
  # Remove Snap plugin from Discover if it somehow ended up installed
  if rpm -q plasma-discover-snap &>/dev/null; then
    run dnf remove -y plasma-discover-snap || true
  fi

  # Old kernel removal (opt-in; guarded to always keep a fallback)
  if [[ "$ALLOW_REMOVE_OLD_KERNELS" -eq 1 ]]; then
    log "Removing old kernels (opt-in) -- keeping latest 2 installonly packages"
    local fallback_count
    fallback_count="$(rpm -qa 'kernel-core' 2>/dev/null | wc -l)"
    if [[ "$fallback_count" -le 1 ]]; then
      warn "Only 1 stock Fedora kernel present -- skipping removal to preserve fallback"
    else
      mapfile -t OLD_KERNELS < <(
        dnf repoquery --installonly --latest-limit=-2 -q 2>/dev/null || true
      )
      if [[ "${#OLD_KERNELS[@]}" -gt 0 ]]; then
        run dnf remove -y "${OLD_KERNELS[@]}" || true
      else
        log "No old kernels found to remove"
      fi
    fi
  else
    log "Old kernel removal skipped (pass --allow-remove-old-kernels to enable)"
  fi

  # Stale cache files (> 30 days old)
  # find handles missing/empty directories cleanly
  find "${REAL_HOME}/.cache" -type f -atime +30 -delete 2>/dev/null || true
  rm -rf "${REAL_HOME}/.cache/thumbnails/"*        2>/dev/null || true
  rm -rf "${REAL_HOME}/.cache/mesa_shader_cache/"* 2>/dev/null || true

  # Firmware updates (list always; apply only if opted in)
  # Note: fwupdmgr exits non-zero when nothing is available -- || true is intentional.
  if command -v fwupdmgr &>/dev/null; then
    run fwupdmgr get-updates || true
    if [[ "$ALLOW_FW_UPDATE" -eq 1 ]]; then
      log "Applying firmware updates (opt-in)"
      run fwupdmgr update -y || true
    else
      log "Firmware updates listed but not applied (pass --allow-fw-update to apply)"
    fi
  fi

  log "Cleanup complete"
}

# ═══════════════════════════════════════════════════════════
# 10. FLATPAK REMOTES
#
# BUG FIX: The original script installed plasma-discover-flatpak
# but never added the Flathub remote. Without Flathub, Discover
# shows almost zero apps (Fedora's OCI repo has very few).
# Confirmed from install logs: this was the actual issue seen.
# ═══════════════════════════════════════════════════════════
setup_flatpak_remotes() {
  log "-- Flatpak remote configuration --"

  if ! command -v flatpak &>/dev/null; then
    log "flatpak not installed -- skipping remote setup"
    return 0
  fi

  if [[ "$DRY_RUN" -eq 1 ]]; then
    log "[DRY-RUN] Would add flathub and fedora remotes"
    return 0
  fi

  # Flathub (main app catalog — required for Discover to show anything useful)
  if ! flatpak remotes --system 2>/dev/null | grep -q '^flathub'; then
    log "Adding Flathub remote (system-wide)"
    flatpak remote-add --if-not-exists --system flathub \
      https://dl.flathub.org/repo/flathub.flatpakrepo || true
    log "Flathub remote added"
  else
    log "OK: Flathub remote already present"
  fi

  # Fedora Flatpak repo (OCI — ships Fedora-built apps)
  if ! flatpak remotes --system 2>/dev/null | grep -q '^fedora'; then
    log "Adding Fedora OCI Flatpak remote"
    flatpak remote-add --if-not-exists --system fedora \
      oci+https://registry.fedoraproject.org || true
  else
    log "OK: Fedora Flatpak remote already present"
  fi

  log "Flatpak remotes configured"
}

# ═══════════════════════════════════════════════════════════
# 11. GAMING SYSCTL
#
# Conservative, well-established gaming tuning only.
# Written to /etc/sysctl.d/ so it survives reboots and
# can be removed cleanly without touching /etc/sysctl.conf.
# ═══════════════════════════════════════════════════════════
apply_gaming_sysctl() {
  log "-- Applying gaming sysctl tuning --"

  local sysctl_file="/etc/sysctl.d/99-gaming.conf"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    log "[DRY-RUN] Would write $sysctl_file"
    return 0
  fi

  if [[ -f "$sysctl_file" ]]; then
    backup_file "$sysctl_file"
  fi

  cat > "$sysctl_file" <<'SYSCTL'
# Gaming sysctl tuning -- written by PostInstallSetup.sh
# Remove this file to revert all changes (takes effect on next boot).

# Reduce swap aggressiveness. With 64 GB+ RAM, keeping working sets in RAM
# is almost always the right call. (Default: 60)
vm.swappiness = 10

# Reduce compaction aggressiveness. CachyOS BORE already handles latency;
# background compaction can cause micro-stutters during heavy scenes.
vm.compaction_proactiveness = 0

# Increase inotify limits. Steam, Proton, and shader caches hit the
# default limits and produce cryptic errors. Recommended by Valve.
fs.inotify.max_user_watches   = 524288
fs.inotify.max_user_instances = 512

# Larger network buffers. Reduces jitter under network load for
# online games. (Defaults: 212992)
net.core.rmem_max = 16777216
net.core.wmem_max = 16777216
SYSCTL

  # Apply immediately without reboot
  run sysctl --system || true
  log "Gaming sysctl applied ($sysctl_file)"
}

# ═══════════════════════════════════════════════════════════
# 12. NFS SHARES (idempotent)
# ═══════════════════════════════════════════════════════════
add_nfs_shares() {
  log "-- NFS share configuration --"

  # Preflight: nfs-utils must be present for mount -a to succeed
  if ! rpm -q nfs-utils &>/dev/null; then
    log "nfs-utils not found -- installing"
    run dnf install -y nfs-utils || true
  fi

  # Create mount point directories owned by the real user
  for entry in "${NFS_ENTRIES[@]}"; do
    local mnt
    mnt="$(awk '{print $2}' <<<"$entry")"
    if [[ ! -d "$mnt" ]]; then
      run mkdir -p -- "$mnt"
    fi
    run chown "${REAL_USER}:${REAL_USER}" -- "$mnt" || true
  done

  if [[ "$DRY_RUN" -eq 1 ]]; then
    log "[DRY-RUN] Would ensure /etc/fstab contains NFS entries"
  else
    backup_file /etc/fstab

    if ! grep -qF "$FSTAB_MARKER" /etc/fstab 2>/dev/null; then
      # First run: append full marker block
      {
        printf '\n%s\n' "$FSTAB_MARKER"
        for entry in "${NFS_ENTRIES[@]}"; do
          printf '%s\n' "$entry"
        done
      } >> /etc/fstab
      log "Appended NFS entries to /etc/fstab"
    else
      # Subsequent runs: add any entries that are missing
      log "fstab marker present -- checking individual entries"
      for entry in "${NFS_ENTRIES[@]}"; do
        local mnt
        mnt="$(awk '{print $2}' <<<"$entry")"
        # Key on mount point column -- robust to whitespace differences
        if ! awk '{print $2}' /etc/fstab | grep -qxF "$mnt"; then
          printf '%s\n' "$entry" >> /etc/fstab
          log "Added missing fstab entry for $mnt"
        else
          log "OK: fstab entry for $mnt already present"
        fi
      done
    fi
  fi

  # mount -a is nonfatal: NFS server may be unreachable during provisioning
  run mount -a || true
  log "NFS configuration complete (mount failures are nonfatal)"
}

# ═══════════════════════════════════════════════════════════
# 13. EXPORT SNAPSHOT METADATA
# ═══════════════════════════════════════════════════════════
export_metadata() {
  log "-- Exporting snapshot metadata --"

  local meta_file="$REAL_HOME/snapshot-meta.txt"
  local flatpak_file="$REAL_HOME/installed-flatpaks.txt"

  if [[ "$DRY_RUN" -eq 0 ]]; then
    {
      echo "=== Snapshot Metadata ==="
      printf "Date    : %s\n" "$(date)"
      printf "Hostname: %s\n" "$(hostname)"
      printf "Kernel  : %s\n" "$(uname -r)"
      printf "Fedora  : %s\n" "$(grep '^VERSION=' /etc/os-release 2>/dev/null || true)"
      if command -v nvidia-smi &>/dev/null; then
        printf "NVIDIA  : %s\n" \
          "$(nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null || echo 'N/A')"
      fi
      echo ""
      echo "=== CachyOS Kernel RPMs ==="
      rpm -qa --queryformat '%{NAME}-%{VERSION}-%{RELEASE}.%{ARCH}\n' \
        'kernel-cachyos*' 2>/dev/null | sort || true
      echo ""
      echo "=== All Installed Packages ==="
      rpm -qa --queryformat '%{NAME}-%{VERSION}-%{RELEASE}.%{ARCH}\n' | sort || true
    } > "$meta_file" 2>/dev/null || true
    chown "${REAL_USER}:${REAL_USER}" "$meta_file" 2>/dev/null || true
    log "Metadata saved to $meta_file"

    if command -v flatpak &>/dev/null; then
      flatpak list --app --columns=name,application > "$flatpak_file" 2>/dev/null || true
      chown "${REAL_USER}:${REAL_USER}" "$flatpak_file" 2>/dev/null || true
      log "Flatpak list saved to $flatpak_file"
    fi
  else
    log "[DRY-RUN] Would write $meta_file and $flatpak_file"
  fi
}

# ═══════════════════════════════════════════════════════════
# 14. FINALIZE
#
# Dracut runs once here -- never earlier -- to avoid double
# regeneration. GRUB was already updated in set_cachyos_kernel_default.
#
# REBOOT GATE: If the NVIDIA module did not build successfully,
# the reboot prompt is suppressed and you get a clear error message.
# Rebooting without the NVIDIA module = black screen on Blackwell.
# ═══════════════════════════════════════════════════════════
finalize() {
  log "-- Finalizing --"

  # Single dracut pass (--regenerate-all covers all installed kernels)
  if command -v dracut &>/dev/null; then
    run dracut --regenerate-all --force || true
  fi

  run journalctl --vacuum-size=100M || true

  cat <<EOF | tee -a "$LOGFILE"

============================================================
  Setup Complete
============================================================
Verify after reboot:
  uname -r                              # should end in -cachyos...
  nvidia-smi                            # RTX 5080 + driver version
  glxinfo | grep "OpenGL renderer"      # should say NVIDIA
  flatpak remotes                       # should show flathub + fedora

Snapshot steps:
  1. Reboot and verify the above.
  2. Boot Rescuezilla live USB.
  3. Image the block device.
  4. Verify checksum; test restore on spare hardware or VM.
  5. Keep $REAL_HOME/snapshot-meta.txt alongside the image.

Fallback: if CachyOS kernel fails to boot, hold Shift at GRUB
and select the stock Fedora kernel entry.
============================================================
EOF

  # ── REBOOT GATE ──────────────────────────────────────────
  if [[ "$NVIDIA_MODULE_OK" -eq 0 ]]; then
    cat <<EOF | tee -a "$LOGFILE"

[REBOOT BLOCKED]
The NVIDIA open kernel module was NOT found for the CachyOS kernel.
Rebooting now will likely result in a black screen (no display driver).

Diagnose:
  journalctl -u akmods --no-pager | tail -80
  ls /lib/modules/*cachyos*/extra/ 2>/dev/null | grep -E 'nvidia|nv'

Fix and retry:
  sudo akmods --force
  sudo $SCRIPT_NAME --noninteractive --hostname $(hostname)

Do NOT reboot until 'nvidia-smi' works from the terminal.
EOF
    return 0
  fi

  if [[ "$NONINTERACTIVE" -eq 0 ]]; then
    read -rp "Reboot now? (y/N): " ans
    if [[ "${ans,,}" == y ]]; then
      run reboot
    fi
  else
    log "Noninteractive mode: skipping reboot prompt"
  fi
}

