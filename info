-- head of script --
sleep 6
#!/usr/bin/env bash
# monitor-split.sh — open a tmux session "sys" with htop (left) and nvtop (right)
SESSION="sys"

# Create session and panes if missing
if ! command -v tmux >/dev/null 2>&1; then
  echo "tmux not installed; please install tmux" >&2
  exit 1
fi

if ! tmux has-session -t "$SESSION" 2>/dev/null; then
  tmux new-session -d -s "$SESSION" 'htop'
  tmux split-window -h -t "$SESSION" 'nvtop'
  tmux select-pane -t 0
fi

# Attach in Konsole
if command -v konsole >/dev/null 2>&1; then
  konsole --noclose --title "MonitorSplit" -e tmux attach -t "$SESSION" &
else
  tmux attach -t "$SESSION"
fi

